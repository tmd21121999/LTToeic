@page "/luyen-thi"
@rendermode InteractiveServer
@inject ITestService TestService
@inject NavigationManager Nav
@inject MessageService Message

<PageTitle>Thư viện đề thi - LTToeic</PageTitle>

<h1 class="library-heading">Thư viện đề thi</h1>
<hr class="library-separator" />

<div class="search-row">
    <input class="search-input-field"
           placeholder="Tìm kiếm đề thi..."
           @bind="_searchText"
           @bind:event="oninput"
           @onkeyup="OnSearchKeyUp" />
    <Button Type="ButtonType.Primary" Class="search-btn" OnClick="FilterTests">Tìm kiếm</Button>
</div>

@if (_loading)
{
    <div class="loading-center"><Spin /></div>
}
else if (_filtered.Count == 0)
{
    <div class="empty-state">Không có đề thi nào phù hợp</div>
}
else
{
    <div class="test-grid">
        @foreach (var test in _filtered)
        {
            <div class="test-card">
                <div class="test-card-info">
                    <div class="test-card-title">@test.Title</div>
                    <div class="test-card-meta">
                        <Icon Type="clock-circle" Theme="IconThemeType.Outline" />
                        @test.Duration phút &nbsp;|&nbsp; @test.TotalQuestions câu
                    </div>
                </div>
                <Button Type="ButtonType.Primary" Class="btn-lam-bai"
                        OnClick='() => Nav.NavigateTo($"/luyen-thi/{test.Id}")'>
                    Làm bài
                </Button>
            </div>
        }
    </div>
}

@code {
    private List<TestViewModel> _all = [];
    private List<TestViewModel> _filtered = [];
    private string _searchText = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await TestService.GetAllAsync();
            _all = all.Where(t => t.Status == TestStatus.Active).ToList();
            _filtered = _all;
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi tải danh sách đề thi: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void FilterTests()
    {
        _filtered = string.IsNullOrWhiteSpace(_searchText)
            ? _all
            : _all.Where(t => t.Title.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") FilterTests();
    }
}
