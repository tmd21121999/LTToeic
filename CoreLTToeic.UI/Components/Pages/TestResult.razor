@page "/ket-qua/{ResultId:long}"
@layout MainLayout
@using AntDesign
@using CoreLTToeic.Application.Interfaces.IService
@using CoreLTToeic.Application.Models.ViewModels
@using CoreLTToeic.Domain.Enums
@inject IUserResultService UserResultService
@inject NavigationManager Nav
@inject IMessageService Message

<PageTitle>Kết quả thi — LTToeic</PageTitle>

@if (_loading)
{
    <div style="text-align:center; padding:80px 0;">
        <Spin Tip="Đang tải kết quả..." />
    </div>
}
else if (_result == null)
{
    <div style="text-align:center; padding:80px 24px;">
        <Icon Type="file-unknown" Theme="@IconThemeType.Outline" Style="font-size:4rem; color:#bfbfbf; display:block; margin-bottom:16px;" />
        <h3 style="color:#595959;">Không tìm thấy kết quả</h3>
        <p style="color:#8c8c8c;">Kết quả thi không tồn tại hoặc đã bị xóa.</p>
        <Button Type="@ButtonType.Primary" OnClick='() => Nav.NavigateTo("/luyen-thi")'>
            Xem đề thi khác
        </Button>
    </div>
}
else
{
    <div style="max-width:960px; margin:0 auto; padding:24px 16px;">

        <div style="text-align:center; margin-bottom:24px;">
            <h2 style="margin-bottom:4px;">Kết quả bài thi</h2>
            <span style="color:#8c8c8c; font-size:1rem;">@_result.TestTitle</span>
            <br />
            <Tag Color="@(_result.TestMode == TestMode.Simulation ? "gold" : "green")" Style="margin-top:8px;">
                @(_result.TestMode == TestMode.Simulation ? "Thi thử TOEIC" : "Luyện tập")
            </Tag>
        </div>

        <TestScoreCard TotalScore="@_result.TotalScore"
                       ListeningScore="@_result.ListeningScore"
                       ReadingScore="@_result.ReadingScore" />

        <Card Style="margin-bottom:24px; border-radius:12px;" Bordered>
            <TestResultStats Correct="@_result.CorrectAnswers"
                             Incorrect="@_result.IncorrectAnswers"
                             Skipped="@_result.SkippedAnswers"
                             Accuracy="@_result.Accuracy"
                             CompletionTimeSeconds="@_result.CompletionTime" />
        </Card>

        <Divider>
            <strong style="font-size:1.1rem;">Xem lại đáp án</strong>
        </Divider>

        @foreach (var partGroup in _partGroups)
        {
            int startNum2 = _partStartNumbers.GetValueOrDefault(partGroup.Key, 1);
            var orderedAnswers = partGroup.OrderBy(a => a.OrderNumber).ToList();
            int idx = 0;
            <div style="margin-top:20px; margin-bottom:8px;">
                <Tag Color="@("blue")" Style="font-size:0.95rem; padding:4px 12px;">
                    @GetPartLabel(partGroup.Key)
                </Tag>
                <span style="color:#8c8c8c; margin-left:8px; font-size:0.9rem;">@partGroup.Count() câu</span>
            </div>
            @foreach (var answer in orderedAnswers)
            {
                int qNum = startNum2 + idx;
                idx++;
                <QuestionReviewItem Answer="answer" QuestionNumber="qNum" />
            }
        }

        <div style="display:flex; justify-content:center; gap:16px; margin-top:32px; margin-bottom:16px; flex-wrap:wrap;">
            <Button OnClick='() => Nav.NavigateTo($"/luyen-thi/{_result.TestId}")'>
                <Icon Type="reload" Theme="@IconThemeType.Outline" /> Làm lại bài này
            </Button>
            <Button Type="@ButtonType.Primary" OnClick='() => Nav.NavigateTo("/luyen-thi")'>
                <Icon Type="unordered-list" Theme="@IconThemeType.Outline" /> Xem đề thi khác
            </Button>
        </div>
    </div>
}

@code {
    [Parameter] public long ResultId { get; set; }

    private UserResultViewModel? _result;
    private bool _loading = true;
    private List<IGrouping<int, UserAnswerViewModel>> _partGroups = [];
    private Dictionary<int, int> _partStartNumbers = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _result = await UserResultService.GetResultAsync(ResultId);
            if (_result != null)
                BuildPartGroups();
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi tải kết quả: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildPartGroups()
    {
        _partGroups = _result!.Answers
            .OrderBy(a => a.PartNum)
            .ThenBy(a => a.OrderNumber)
            .GroupBy(a => a.PartNum)
            .ToList();

        int counter = 1;
        _partStartNumbers = [];
        foreach (var group in _partGroups)
        {
            _partStartNumbers[group.Key] = counter;
            counter += group.Count();
        }
    }

    private static string GetPartLabel(int partNum) => partNum switch
    {
        1 => "Part 1 — Photographs",
        2 => "Part 2 — Question-Response",
        3 => "Part 3 — Conversations",
        4 => "Part 4 — Talks",
        5 => "Part 5 — Incomplete Sentences",
        6 => "Part 6 — Text Completion",
        7 => "Part 7 — Reading Comprehension",
        _ => $"Part {partNum}"
    };
}
