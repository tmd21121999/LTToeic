@page "/"
@inject NavigationManager Nav

<PageTitle>LTToeic - Hệ Thống Luyện Thi TOEIC</PageTitle>

<div>
    <h1 class="structure-heading">Cấu Trúc Bài Thi TOEIC Mới</h1>
    <hr class="structure-separator" />

    <div class="structure-grid">
        <div>
            <div class="structure-section-title">
                <Icon Type="customer-service" Theme="IconThemeType.Outline" />
                Listening (45 Phút)
            </div>
            <div class="structure-part-list">
                <div class="structure-part-item">Part 1: Photographs (6 câu)</div>
                <div class="structure-part-item">Part 2: Question-Response (25 câu)</div>
                <div class="structure-part-item">Part 3: Conversations (39 câu)</div>
                <div class="structure-part-item">Part 4: Short Talks (30 câu)</div>
            </div>
        </div>
        <div>
            <div class="structure-section-title">
                <Icon Type="read" Theme="IconThemeType.Outline" />
                Reading (75 Phút)
            </div>
            <div class="structure-part-list">
                <div class="structure-part-item">Part 5: Incomplete Sentences (30 câu)</div>
                <div class="structure-part-item">Part 6: Text Completion (16 câu)</div>
                <div class="structure-part-item">Part 7: Reading Comprehension (54 câu)</div>
            </div>
        </div>
    </div>

    <div class="structure-cta">
        <Button Type="ButtonType.Primary" Class="btn-primary" OnClick="@(() => Nav.NavigateTo("/luyen-thi"))">
            <Icon Type="right-circle" Theme="IconThemeType.Outline" />
            Bắt đầu luyện thi
        </Button>
    </div>
</div>
