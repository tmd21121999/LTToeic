@page "/login"
@inject IAuthRepository AuthRepository
@inject MessageService Message
@inject NavigationManager Navigation

<PageTitle>Đăng nhập - LTToeic</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-brand-logo">LTToeic</div>
        </div>
        <h2 class="auth-title">Đăng nhập</h2>

        <Form Model="@_model" OnFinish="OnFinish" Layout="@FormLayout.Vertical">
            <FormItem Label="Tên đăng nhập" Required>
                <Input @bind-Value="_model.UserName" Placeholder="Nhập tên đăng nhập" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Label="Mật khẩu" Required>
                <InputPassword @bind-Value="_model.Password" Placeholder="Nhập mật khẩu" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Style="margin-bottom:0">
                <Button Type="ButtonType.Primary" HtmlType="submit" Block Size="@AntDesign.ButtonSize.Large"
                        Style="background:#1B527A;border-color:#1B527A;font-weight:600;height:44px">
                    Đăng nhập
                </Button>
            </FormItem>
        </Form>

        <div class="auth-footer">
            Chưa có tài khoản?
            <a href="/register">Đăng ký ngay</a>
        </div>
    </div>
</div>

@code {
    private LoginEditModel _model = new();

    private async Task OnFinish()
    {
        try
        {
            var result = await AuthRepository.Login(_model);
            if (result.Succeeded)
            {
                await Message.SuccessAsync("Đăng nhập thành công!");
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                var errors = string.Join("; ", result.Errors.Select(e => e.Description));
                await Message.ErrorAsync($"Đăng nhập thất bại: {errors}");
            }
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi: {ex.Message}");
        }
    }
}
