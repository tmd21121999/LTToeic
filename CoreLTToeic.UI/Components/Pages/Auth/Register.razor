@page "/register"
@inject IAuthRepository AuthRepository
@inject MessageService Message
@inject NavigationManager Navigation

<PageTitle>Đăng ký - LTToeic</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-brand-logo">LTToeic</div>
        </div>
        <h2 class="auth-title">Tạo tài khoản</h2>

        <Form Model="@_model" OnFinish="OnFinish" Layout="@FormLayout.Vertical">
            <FormItem Label="Tên đăng nhập" Required>
                <Input @bind-Value="_model.UserName" Placeholder="Nhập tên đăng nhập" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Label="Email" Required>
                <Input @bind-Value="_model.Email" Placeholder="Nhập email" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Label="Họ và tên">
                <Input @bind-Value="_model.FullName" Placeholder="Nhập họ và tên" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Label="Mật khẩu" Required>
                <InputPassword @bind-Value="_model.Password" Placeholder="Nhập mật khẩu" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Label="Xác nhận mật khẩu" Required>
                <InputPassword @bind-Value="_model.ConfirmPassword" Placeholder="Nhập lại mật khẩu" Size="@InputSize.Large" />
            </FormItem>
            <FormItem Style="margin-bottom:0">
                <Button Type="ButtonType.Primary" HtmlType="submit" Block Size="@AntDesign.ButtonSize.Large"
                        Style="background:#1B527A;border-color:#1B527A;font-weight:600;height:44px">
                    Đăng ký
                </Button>
            </FormItem>
        </Form>

        <div class="auth-footer">
            Đã có tài khoản?
            <a href="/login">Đăng nhập</a>
        </div>
    </div>
</div>

@code {
    private RegisterEditModel _model = new();

    private async Task OnFinish()
    {
        if (string.IsNullOrWhiteSpace(_model.Password) || _model.Password != _model.ConfirmPassword)
        {
            await Message.ErrorAsync("Mật khẩu xác nhận không khớp");
            return;
        }

        try
        {
            var result = await AuthRepository.Register(_model);
            if (result.Succeeded)
            {
                await Message.SuccessAsync("Đăng ký thành công! Vui lòng kiểm tra email để xác nhận tài khoản.");
                Navigation.NavigateTo("/login");
            }
            else
            {
                var errors = string.Join("; ", result.Errors.Select(e => e.Description));
                await Message.ErrorAsync($"Đăng ký thất bại: {errors}");
            }
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi: {ex.Message}");
        }
    }
}
