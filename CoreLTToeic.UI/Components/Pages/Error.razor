@page "/Error"
@using System.Diagnostics

<PageTitle>Lỗi - LTToeic</PageTitle>

<h1 class="text-danger">Đã xảy ra lỗi.</h1>
<h2 class="text-danger">Có lỗi trong quá trình xử lý yêu cầu của bạn.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@RequestId</code>
    </p>
}

<h3>Chế độ phát triển</h3>
<p>
    Chuyển sang môi trường <strong>Development</strong> để xem thông tin chi tiết hơn về lỗi đã xảy ra.
</p>
<p>
    <strong>Không nên bật môi trường Development trên ứng dụng đã triển khai.</strong>
    Điều này có thể khiến thông tin nhạy cảm từ ngoại lệ bị hiển thị cho người dùng.
    Để debug cục bộ, hãy bật môi trường <strong>Development</strong> bằng cách đặt biến môi trường
    <strong>ASPNETCORE_ENVIRONMENT</strong> thành <strong>Development</strong> rồi khởi động lại ứng dụng.
</p>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
