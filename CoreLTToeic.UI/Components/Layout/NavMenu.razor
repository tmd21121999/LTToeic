@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthStateProvider
@inject SignInManager<AppUser> SignInManager
@inject NavigationManager Nav

<header class="top-navbar">
    <a class="nav-brand" href="/">LTToeic</a>
    <nav class="nav-links">
        <NavLink href="/" Match="NavLinkMatch.All">Trang chủ</NavLink>
        <NavLink href="/luyen-thi">Đề thi Online</NavLink>
        <span class="nav-link-disabled">Khóa học</span>
        <span class="nav-link-disabled">Tài liệu</span>
    </nav>
    <div class="nav-user">
        @if (_isLoggedIn)
        {
            <span class="nav-user-name">@_displayName</span>
            <button class="nav-logout-btn" @onclick="Logout">Đăng xuất</button>
        }
        else
        {
            <a href="/login" class="nav-user-icon" title="Đăng nhập">
                <Icon Type="user" Theme="IconThemeType.Outline" />
            </a>
        }
    </div>
</header>

@code {
    private bool _isLoggedIn;
    private string _displayName = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _isLoggedIn = state.User.Identity?.IsAuthenticated ?? false;
        if (_isLoggedIn)
        {
            _displayName = state.User.FindFirst("FullName")?.Value
                           ?? state.User.Identity?.Name
                           ?? "Người dùng";
        }
    }

    private async Task Logout()
    {
        await SignInManager.SignOutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
