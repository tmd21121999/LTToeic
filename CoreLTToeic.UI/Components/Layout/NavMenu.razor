@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IAuthRepository AuthRepository
@inject IUserResultService UserResultService
@inject MessageService Message

<header class="top-navbar">
    <a class="nav-brand" href="/">LTToeic</a>
    <nav class="nav-links">
        <NavLink href="/" Match="NavLinkMatch.All">Trang chủ</NavLink>
        <NavLink href="/luyen-thi">Đề thi Online</NavLink>
        @if (_isLoggedIn)
        {
            <NavLink href="/tong-quan">Tổng quan</NavLink>
        }
        <span class="nav-link-disabled">Khóa học</span>
        <span class="nav-link-disabled">Tài liệu</span>
    </nav>
    <div class="nav-user">
        @if (_isLoggedIn)
        {
            <Dropdown Trigger="@(new[] { Trigger.Click })" Placement="Placement.BottomRight">
                <Overlay>
                    <Menu>
                        <MenuItem Key="profile" OnClick="@(async () => await OpenProfileDrawer())">
                            <Icon Type="user" Theme="IconThemeType.Outline" />
                            <span>Thiết lập hồ sơ</span>
                        </MenuItem>
                        <MenuItem Key="history" OnClick="@(async () => await OpenHistoryDrawer())">
                            <Icon Type="history" Theme="IconThemeType.Outline" />
                            <span>Lịch sử thi</span>
                        </MenuItem>
                        <MenuItem Key="password" OnClick="@(() => OpenPasswordDrawer())">
                            <Icon Type="lock" Theme="IconThemeType.Outline" />
                            <span>Đổi mật khẩu</span>
                        </MenuItem>
                        <MenuDivider />
                        <MenuItem Key="logout" OnClick="@(() => Logout())">
                            <Icon Type="logout" Theme="IconThemeType.Outline" />
                            <span>Đăng xuất</span>
                        </MenuItem>
                    </Menu>
                </Overlay>
                <ChildContent>
                    <span class="nav-user-name" style="cursor:pointer">
                        <Icon Type="user" Theme="IconThemeType.Outline" Style="margin-right:6px" />
                        @_displayName
                        <Icon Type="down" Theme="IconThemeType.Outline" Style="margin-left:4px;font-size:11px" />
                    </span>
                </ChildContent>
            </Dropdown>
        }
        else
        {
            <a href="/login" class="nav-user-icon" title="Đăng nhập">
                <Icon Type="user" Theme="IconThemeType.Outline" />
            </a>
        }
    </div>
</header>

<Drawer Visible="_profileDrawerOpen"
        Title="@("Thiết lập hồ sơ")"
        Width="420"
        OnClose="CloseDrawers">
    <Form Model="_profileModel" OnFinish="SaveProfile" Layout="@FormLayout.Vertical">
        <FormItem Label="Họ và tên" Required>
            <Input @bind-Value="_profileModel.FullName" Placeholder="Nhập họ và tên" />
        </FormItem>
        <FormItem Label="Số điện thoại">
            <Input @bind-Value="_profileModel.PhoneNumber" Placeholder="Nhập số điện thoại" />
        </FormItem>
        <FormItem Label="Ngày sinh">
            <DatePicker TValue="DateTime?" @bind-Value="_profileModel.DateOfBirth" Style="width:100%" />
        </FormItem>
        <FormItem>
            <Button Type="ButtonType.Primary" HtmlType="submit" Loading="_saving">Lưu thay đổi</Button>
            <Button Style="margin-left:8px" OnClick="CloseDrawers">Huỷ</Button>
        </FormItem>
    </Form>
</Drawer>

<Drawer Visible="_passwordDrawerOpen"
        Title="@("Đổi mật khẩu")"
        Width="420"
        OnClose="CloseDrawers">
    <Form Model="_passwordModel" OnFinish="SavePassword" Layout="@FormLayout.Vertical">
        <FormItem Label="Mật khẩu hiện tại" Required>
            <InputPassword @bind-Value="_passwordModel.OldPassword" Placeholder="Nhập mật khẩu hiện tại" />
        </FormItem>
        <FormItem Label="Mật khẩu mới" Required>
            <InputPassword @bind-Value="_passwordModel.NewPassword" Placeholder="Nhập mật khẩu mới" />
        </FormItem>
        <FormItem Label="Xác nhận mật khẩu mới" Required>
            <InputPassword @bind-Value="_passwordModel.ConfirmPassword" Placeholder="Nhập lại mật khẩu mới" />
        </FormItem>
        <FormItem>
            <Button Type="ButtonType.Primary" HtmlType="submit" Loading="_saving">Đổi mật khẩu</Button>
            <Button Style="margin-left:8px" OnClick="CloseDrawers">Huỷ</Button>
        </FormItem>
    </Form>
</Drawer>

<Drawer Visible="_historyDrawerOpen"
        Title="@("Lịch sử thi")"
        Width="900"
        OnClose="CloseDrawers">
    @if (_historyLoading)
    {
        <div style="text-align:center; padding:48px 0;">
            <Spin Tip="Đang tải..." />
        </div>
    }
    else
    {
        <ExamHistoryTable Results="_historyResults" />
    }
</Drawer>

@code {
    private bool _isLoggedIn;
    private string _displayName = "";
    private string _userId = "";

    private bool _profileDrawerOpen;
    private bool _passwordDrawerOpen;
    private bool _historyDrawerOpen;
    private bool _historyLoading;
    private bool _saving;

    private UpdateProfileEditModel _profileModel = new();
    private ChangePasswordModel _passwordModel = new();
    private List<UserResultViewModel> _historyResults = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _isLoggedIn = state.User.Identity?.IsAuthenticated ?? false;
        if (_isLoggedIn)
        {
            _displayName = state.User.FindFirst("FullName")?.Value
                           ?? state.User.Identity?.Name
                           ?? "Người dùng";
            _userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        }
    }

    private async Task OpenProfileDrawer()
    {
        if (string.IsNullOrEmpty(_userId)) return;
        try
        {
            var user = await AuthRepository.GetByIdAsync(_userId);
            if (user != null)
            {
                _profileModel = new UpdateProfileEditModel
                {
                    FullName = user.FullName ?? "",
                    PhoneNumber = user.PhoneNumber,
                    DateOfBirth = user.DateOfBirth
                };
            }
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi tải thông tin: {ex.Message}");
        }
        _profileDrawerOpen = true;
    }

    private async Task OpenHistoryDrawer()
    {
        _historyDrawerOpen = true;
        _historyLoading = true;
        try
        {
            var data = await UserResultService.GetByUserIdAsync(_userId);
            _historyResults = data.ToList();
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi tải lịch sử: {ex.Message}");
        }
        finally
        {
            _historyLoading = false;
        }
    }

    private void OpenPasswordDrawer()
    {
        _passwordModel = new ChangePasswordModel();
        _passwordDrawerOpen = true;
    }

    private void CloseDrawers()
    {
        _profileDrawerOpen = false;
        _passwordDrawerOpen = false;
        _historyDrawerOpen = false;
    }

    private async Task SaveProfile()
    {
        _saving = true;
        try
        {
            var result = await AuthRepository.UpdateProfileAsync(_userId, _profileModel);
            if (result.Succeeded)
            {
                await Message.SuccessAsync("Cập nhật hồ sơ thành công!");
                _displayName = _profileModel.FullName;
                CloseDrawers();
            }
            else
            {
                var errors = string.Join("; ", result.Errors.Select(e => e.Description));
                await Message.ErrorAsync($"Lỗi: {errors}");
            }
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SavePassword()
    {
        if (_passwordModel.NewPassword != _passwordModel.ConfirmPassword)
        {
            await Message.ErrorAsync("Mật khẩu xác nhận không khớp!");
            return;
        }
        _saving = true;
        try
        {
            var result = await AuthRepository.ChangePasswordAsync(_userId, _passwordModel.OldPassword, _passwordModel.NewPassword);
            if (result.Succeeded)
            {
                await Message.SuccessAsync("Đổi mật khẩu thành công!");
                CloseDrawers();
            }
            else
            {
                var errors = string.Join("; ", result.Errors.Select(e => e.Description));
                await Message.ErrorAsync($"Lỗi: {errors}");
            }
        }
        catch (Exception ex)
        {
            await Message.ErrorAsync($"Lỗi: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private void Logout()
    {
        Nav.NavigateTo("/api/auth/signout", forceLoad: true);
    }

    private class ChangePasswordModel
    {
        public string OldPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
