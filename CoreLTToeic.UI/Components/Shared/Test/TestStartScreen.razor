@using AntDesign
@using CoreLTToeic.Application.Models.ViewModels
@using CoreLTToeic.Domain.Enums

<div style="display:flex; justify-content:center; align-items:center; min-height:70vh; padding:24px;">
    <Card Style="max-width:560px; width:100%; border-radius:16px; box-shadow:0 4px 24px rgba(0,0,0,0.1);">
        <div style="text-align:center; margin-bottom:24px;">
            <Icon Type="file-text" Theme="@IconThemeType.Outline" Style="font-size:3rem; color:#1B527A;" />
            <h2 style="margin-top:8px; margin-bottom:4px;">@Test?.Title</h2>
            <span style="color:#8c8c8c;">@Test?.TotalQuestions câu hỏi</span>
        </div>

        <Divider>Chọn chế độ thi</Divider>

        <RadioGroup @bind-Value="_mode" Style="width:100%;">
            <div style="display:flex; flex-direction:column; gap:10px;">
                <div style="border:1px solid #d9d9d9; border-radius:8px; padding:12px 16px;">
                    <Radio Value="@TestMode.Simulation">
                        <Icon Type="trophy" Theme="@IconThemeType.Outline" Style="color:#faad14; margin-right:6px;" />
                        <strong>Thi thử TOEIC</strong>
                        <span style="color:#8c8c8c; font-size:0.85rem; display:block; padding-left:22px;">Cố định 120 phút — đúng chuẩn TOEIC</span>
                    </Radio>
                </div>
                <div style="border:1px solid #d9d9d9; border-radius:8px; padding:12px 16px;">
                    <Radio Value="@TestMode.Practice">
                        <Icon Type="book" Theme="@IconThemeType.Outline" Style="color:#52c41a; margin-right:6px;" />
                        <strong>Luyện tập</strong>
                        <span style="color:#8c8c8c; font-size:0.85rem; display:block; padding-left:22px;">Tự chọn thời gian hoặc không giới hạn</span>
                    </Radio>
                </div>
            </div>
        </RadioGroup>

        @if (_mode == TestMode.Practice)
        {
            <Divider>Thời gian luyện tập</Divider>
            <RadioGroup @bind-Value="_duration" Style="width:100%;">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                    <div style="border:1px solid #d9d9d9; border-radius:8px; padding:10px; text-align:center;">
                        <Radio Value="0">
                            <Icon Type="clock-circle" Theme="@IconThemeType.Outline" Style="color:#1B527A;" />
                            Không giới hạn
                        </Radio>
                    </div>
                    <div style="border:1px solid #d9d9d9; border-radius:8px; padding:10px; text-align:center;">
                        <Radio Value="30">30 phút</Radio>
                    </div>
                    <div style="border:1px solid #d9d9d9; border-radius:8px; padding:10px; text-align:center;">
                        <Radio Value="60">60 phút</Radio>
                    </div>
                    <div style="border:1px solid #d9d9d9; border-radius:8px; padding:10px; text-align:center;">
                        <Radio Value="90">90 phút</Radio>
                    </div>
                    <div style="border:1px solid #d9d9d9; border-radius:8px; padding:10px; text-align:center; grid-column:span 2;">
                        <Radio Value="120">120 phút</Radio>
                    </div>
                </div>
            </RadioGroup>
        }

        <div style="text-align:center; margin-top:28px;">
            <Button Type="@ButtonType.Primary" OnClick="HandleStart"
                    Style="min-width:160px; height:48px; font-size:1rem; border-radius:8px;">
                Bắt đầu thi &nbsp;
                <Icon Type="arrow-right" Theme="@IconThemeType.Outline" />
            </Button>
        </div>
    </Card>
</div>

@code {
    [Parameter, EditorRequired] public TestViewModel? Test { get; set; }
    [Parameter] public EventCallback<(TestMode Mode, int DurationMinutes)> OnStart { get; set; }

    private TestMode _mode = TestMode.Simulation;
    private int _duration = 0;

    private async Task HandleStart()
    {
        var minutes = _mode == TestMode.Simulation ? 120 : _duration;
        await OnStart.InvokeAsync((_mode, minutes));
    }
}
