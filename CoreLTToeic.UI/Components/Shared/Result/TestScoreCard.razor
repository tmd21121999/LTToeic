@using AntDesign

@if (TestMode == TestMode.Simulation)
{
    <div style="display:flex; gap:16px; margin-bottom:24px; flex-wrap:wrap; justify-content:center;">
        <Card Bordered Style="flex:1; min-width:180px; text-align:center; background:linear-gradient(135deg,#1B527A,#2471A3); color:#fff; border-radius:12px;">
            <Statistic Title="Tổng điểm"
                       Value="@TotalScore"
                       Suffix="/ 990"
                       ValueStyle="font-size:2.5rem; font-weight:700; color:#fff;" />
        </Card>
        <Card Bordered Style="flex:1; min-width:160px; text-align:center; border-radius:12px;">
            <Statistic Title="Listening"
                       Value="@ListeningScore"
                       Suffix="/ 495"
                       ValueStyle="font-size:2rem; font-weight:600; color:#1B527A;" />
        </Card>
        <Card Bordered Style="flex:1; min-width:160px; text-align:center; border-radius:12px;">
            <Statistic Title="Reading"
                       Value="@ReadingScore"
                       Suffix="/ 495"
                       ValueStyle="font-size:2rem; font-weight:600; color:#2471A3;" />
        </Card>
    </div>
}
else
{
    <div style="display:flex; gap:16px; margin-bottom:24px; flex-wrap:wrap; justify-content:center;">
        <Card Bordered Style="flex:1; min-width:180px; text-align:center; background:linear-gradient(135deg,#1B527A,#2471A3); color:#fff; border-radius:12px;">
            <Statistic Title="Số câu đúng"
                       Value="@CorrectAnswers"
                       Suffix="@($"/ {_totalQ} câu")"
                       ValueStyle="font-size:2.5rem; font-weight:700; color:#fff;" />
            <div style="color:rgba(255,255,255,0.72); font-size:0.82rem; margin-top:6px;">
                Điểm ước tính: ~@TotalScore / 990
            </div>
        </Card>
        <Card Bordered Style="flex:1; min-width:160px; text-align:center; border-radius:12px;">
            <Statistic Title="Nghe đúng"
                       Value="@ListeningCorrects"
                       Suffix="@($"/ {TotalListeningQuestions} câu")"
                       ValueStyle="font-size:2rem; font-weight:600; color:#1B527A;" />
            <div style="color:#8c8c8c; font-size:0.8rem; margin-top:4px;">~@ListeningScore / 495</div>
        </Card>
        <Card Bordered Style="flex:1; min-width:160px; text-align:center; border-radius:12px;">
            <Statistic Title="Đọc đúng"
                       Value="@ReadingCorrects"
                       Suffix="@($"/ {TotalReadingQuestions} câu")"
                       ValueStyle="font-size:2rem; font-weight:600; color:#2471A3;" />
            <div style="color:#8c8c8c; font-size:0.8rem; margin-top:4px;">~@ReadingScore / 495</div>
        </Card>
    </div>
}

@code {
    [Parameter] public int TotalScore { get; set; }
    [Parameter] public int ListeningScore { get; set; }
    [Parameter] public int ReadingScore { get; set; }
    [Parameter] public TestMode TestMode { get; set; } = TestMode.Practice;
    [Parameter] public int ListeningCorrects { get; set; }
    [Parameter] public int ReadingCorrects { get; set; }
    [Parameter] public int CorrectAnswers { get; set; }
    [Parameter] public int TotalListeningQuestions { get; set; }
    [Parameter] public int TotalReadingQuestions { get; set; }

    private int _totalQ => TotalListeningQuestions + TotalReadingQuestions;
}
