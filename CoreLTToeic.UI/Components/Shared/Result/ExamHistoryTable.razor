@inject NavigationManager Nav

@if (Results.Count == 0)
{
    <Empty Description="@("Chưa có lịch sử thi")" />
}
else
{
    <Table DataSource="Results" TItem="UserResultViewModel" Bordered PageSize="@(Compact ? Results.Count : 20)">
        @if (!Compact)
        {
            <ActionColumn Title="STT" Width="60">
                @(Results.IndexOf(context) + 1)
            </ActionColumn>
        }
        <ActionColumn Title="Tên đề thi">
            <span style="font-weight:500;">@context.TestTitle</span>
        </ActionColumn>
        <ActionColumn Title="Chế độ" Width="130">
            <Tag Color="@(context.TestMode == TestMode.Simulation ? "gold" : "green")">
                @(context.TestMode == TestMode.Simulation ? "Thi thử" : "Luyện tập")
            </Tag>
        </ActionColumn>
        <ActionColumn Title="Ngày thi" Width="150">
            @context.CompletedAt?.ToString("dd/MM/yyyy HH:mm")
        </ActionColumn>
        <ActionColumn Title="Nghe / Đọc" Width="120">
            <span style="color:#1B527A; font-weight:600;">@context.ListeningScore</span>
            <span style="color:#bfbfbf;"> / </span>
            <span style="color:#2471A3; font-weight:600;">@context.ReadingScore</span>
        </ActionColumn>
        <ActionColumn Title="Tổng điểm" Width="110">
            <Tag Color="@ScoreColor(context.TotalScore)" Style="font-size:0.95rem; font-weight:700; padding:2px 10px;">
                @context.TotalScore
            </Tag>
        </ActionColumn>
        @if (!Compact)
        {
            <ActionColumn Title="Chính xác" Width="100">
                @context.Accuracy.ToString("0.#")%
            </ActionColumn>
            <ActionColumn Title="Thời gian" Width="100">
                @FormatTime(context.CompletionTime)
            </ActionColumn>
        }
        <ActionColumn Title="Thao tác" Width="@(Compact ? "90" : "160")">
            <Space>
                <SpaceItem>
                    <Button Size="ButtonSize.Small" Icon="eye"
                            OnClick='() => Nav.NavigateTo($"/ket-qua/{context.Id}")'>
                        Xem
                    </Button>
                </SpaceItem>
                @if (!Compact)
                {
                    <SpaceItem>
                        <Button Size="ButtonSize.Small" Icon="reload"
                                OnClick='() => Nav.NavigateTo($"/luyen-thi/{context.TestId}")'>
                            Làm lại
                        </Button>
                    </SpaceItem>
                }
            </Space>
        </ActionColumn>
    </Table>
}

@code {
    [Parameter] public List<UserResultViewModel> Results { get; set; } = [];
    [Parameter] public bool Compact { get; set; } = false;

    private static string ScoreColor(int score) => score >= 800 ? "success" : score >= 500 ? "warning" : "error";

    private static string FormatTime(int seconds)
    {
        var m = seconds / 60;
        var s = seconds % 60;
        return $"{m:D2}:{s:D2}";
    }
}
